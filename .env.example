# Pico reads these six generic variables from the repository-root .env file.
# Project .env values take precedence over process environment values.

# Anthropic (default)
PICO_PROVIDER=anthropic
PICO_MODEL=claude-sonnet-4-6
PICO_API_URL=https://api.anthropic.com/v1
PICO_API_KEY=
PICO_API_VARIANT=auto
PICO_AUTH_MODE=auto

# OpenAI Responses API
# PICO_PROVIDER=openai
# PICO_MODEL=gpt-5.4
# PICO_API_URL=https://api.openai.com/v1
# PICO_API_KEY=your-openai-api-key
# PICO_API_VARIANT=responses
# PICO_AUTH_MODE=bearer

# OpenAI-compatible Chat Completions gateway
# PICO_PROVIDER=openai
# PICO_MODEL=your-model-name
# PICO_API_URL=https://gateway.example/v1
# PICO_API_KEY=your-gateway-api-key
# PICO_API_VARIANT=chat_completions
# PICO_AUTH_MODE=bearer

# Local Ollama (API key is intentionally empty)
# PICO_PROVIDER=ollama
# PICO_MODEL=qwen3:8b
# PICO_API_URL=http://127.0.0.1:11434
# PICO_API_KEY=
# PICO_API_VARIANT=auto
# PICO_AUTH_MODE=none
