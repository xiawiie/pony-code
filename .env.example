# Copy this file to .env and fill only the providers you use.

# Optional provider selector. CLI --provider still takes precedence.
PICO_PROVIDER=deepseek

# Recommended default. DeepSeek uses its Anthropic-compatible endpoint.
PICO_DEEPSEEK_API_BASE=https://api.deepseek.com/anthropic
PICO_DEEPSEEK_API_KEY=
PICO_DEEPSEEK_MODEL=deepseek-v4-pro

# Optional right.codes shared key. Used by --provider openai and --provider anthropic when provider-specific keys are empty.
PICO_RIGHT_CODES_API_KEY=

# Default OpenAI-compatible endpoint. Change this if you use another /responses-compatible service.
PICO_OPENAI_API_BASE=https://www.right.codes/codex/v1
PICO_OPENAI_API_KEY=
PICO_OPENAI_MODEL=gpt-5.4

# Default Anthropic-compatible endpoint. Can reuse PICO_RIGHT_CODES_API_KEY when your gateway shares one key.
PICO_ANTHROPIC_API_BASE=https://www.right.codes/claude/v1
PICO_ANTHROPIC_API_KEY=
PICO_ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional comma-separated extra env names to redact from traces and reports.
PICO_SECRET_ENV_NAMES=
