# Pico reads these three variables from the repository-root .env file.
# Project .env values take precedence over process environment values.
# Provider, wire protocol, and authentication are derived from PICO_API_BASE.

# Anthropic example
PICO_API_BASE=https://api.anthropic.com/v1
PICO_API_KEY=
PICO_MODEL=claude-sonnet-4-6

# OpenAI Responses API
# PICO_API_BASE=https://api.openai.com/v1
# PICO_API_KEY=your-openai-api-key
# PICO_MODEL=gpt-5.4

# OpenAI-compatible Chat Completions gateway
# PICO_API_BASE=https://gateway.example/v1
# PICO_API_KEY=your-gateway-api-key
# PICO_MODEL=your-model-name

# Local Ollama (API key is intentionally empty)
# PICO_API_BASE=http://127.0.0.1:11434
# PICO_API_KEY=
# PICO_MODEL=qwen3:8b
